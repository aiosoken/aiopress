rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isAuthenticated() {
      return request.auth != null;
    }

    function isBrandMember(brandId) {
      return isAuthenticated() &&
        exists(/databases/$(database)/documents/brandMembers/$(brandId + '_' + request.auth.uid));
    }

    function isBrandOwnerOrAdmin(brandId) {
      let member = get(/databases/$(database)/documents/brandMembers/$(brandId + '_' + request.auth.uid));
      return isAuthenticated() &&
        member != null &&
        (member.data.role == 'OWNER' || member.data.role == 'ADMIN');
    }

    // ユーザープロファイル
    match /users/{userId} {
      allow read, write: if isAuthenticated() && request.auth.uid == userId;
    }

    // ブランド
    match /brands/{brandId} {
      allow read: if resource.data.ownerId == request.auth.uid || isBrandMember(brandId);
      allow create: if isAuthenticated();
      allow update: if isBrandOwnerOrAdmin(brandId);
      allow delete: if isAuthenticated() &&
        get(/databases/$(database)/documents/brandMembers/$(brandId + '_' + request.auth.uid)).data.role == 'OWNER';
    }

    // ブランドメンバー
    match /brandMembers/{memberId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated();
      allow update, delete: if isAuthenticated() &&
        (resource.data.userId == request.auth.uid ||
         isBrandOwnerOrAdmin(resource.data.brandId));
    }

    // 資産（list操作ではexists()が使えないためget/listを分離）
    match /assets/{assetId} {
      allow get: if isAuthenticated() && isBrandMember(resource.data.brandId);
      allow list: if isAuthenticated();
      allow create: if isAuthenticated();
      allow update, delete: if isAuthenticated() && isBrandMember(resource.data.brandId);
    }

    // デザインシステム
    match /designSystems/{brandId} {
      allow read: if isBrandMember(brandId);
      allow write: if isBrandOwnerOrAdmin(brandId);
    }

    // クリエイティブ（list操作ではexists()が使えないためget/listを分離）
    match /creatives/{creativeId} {
      allow get: if isAuthenticated() && isBrandMember(resource.data.brandId);
      allow list: if isAuthenticated();
      allow create: if isAuthenticated();
      allow update, delete: if isAuthenticated() && isBrandMember(resource.data.brandId);
    }
  }
}
